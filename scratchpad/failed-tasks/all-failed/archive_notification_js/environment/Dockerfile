FROM ubuntu:24.04

RUN apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        curl wget ca-certificates git python3 python3-pip python3-pytest bash ripgrep && \
    curl -fsSL https://deb.nodesource.com/setup_24.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    pip3 install --break-system-packages pytest-json-ctrf requests PyJWT && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN mkdir -p /home/user && chmod 0755 /home/user

RUN mkdir -p /home/user/myproject && \
    cd /home/user/myproject && \
    cat >package.json <<'EOF'
{
  "name": "archive-notification-js",
  "version": "1.0.0",
  "private": true,
  "description": "Seed project for archiving a MagicBell notification with magicbell-js.",
  "type": "commonjs"
}
EOF

RUN cd /home/user/myproject && \
    npm install --no-audit --no-fund --silent magicbell-js jsonwebtoken tslib

LABEL Author="generate-harbor-tasks"
LABEL Description="Node.js task environment with magicbell-js and jsonwebtoken pre-installed for archiving a MagicBell notification."

CMD ["/bin/bash", "-c", "trap : TERM INT; sleep infinity & wait"]

# Container contents:
#   - always required apt packages: curl wget ca-certificates git python3 python3-pip python3-pytest bash ripgrep
#   - always required pip3 packages: pytest-json-ctrf
#   - additional pip3 packages: requests, PyJWT (used by the final-state verifier to sign User JWTs and call MagicBell REST)
#   - Node.js v24 for running magicbell-js
#   - /home/user/myproject: pre-seeded Node.js project with magicbell-js, jsonwebtoken, and tslib already installed
